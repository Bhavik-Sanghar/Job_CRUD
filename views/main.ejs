<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All User</title>
    <link rel="stylesheet" href="/css/view.css">
</head>
<body>
   <div class="container">
    <h2>Applicant List</h2>
    <div class="grid">
    <% db_data.forEach(e => { %>
        <div class="card" id="applicant-<%= e.id %>">
            <div class="card-header">
                <h3><%= e.first_name %> <%= e.last_name %></h3>
                <span class="badge"><%= e.designation %></span>
            </div>
            
            <div class="card-body">
                <p><strong>Email:</strong> <%= e.email %></p>
                <p><strong>Phone:</strong> <%= e.phone %></p>
                <p><strong>Location:</strong> <%= e.city %></p>
            </div>

            <div class="card-actions">
                <a href="/edit-applicant?id=<%= e.applicant_id %>" class="btn btn-edit">Edit</a>                
                <a href="/delete-applicant/?id=<%= e.applicant_id %>" 
                   class="btn btn-delete" 
                   onclick="return confirm('Are you sure you want to delete this applicant?')">
                   Delete
                </a>
            </div>
        </div>
    <% }) %>
</div>

</div>

</html>